DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fonly"
AUTH_SECRET="replace-with-a-long-random-secret"
# Google OAuth — her ikisi de doluysa "Google ile giriş" butonu aktifleşir.
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://ALAN-ADIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Ödeme sağlayıcısı. Varsayılan "dev" — gerçek PSP olmadan abonelik akışını
# test eder (lib/billing/providers/dev.ts). "dev" production'da kapalıdır;
# geçici test için ALLOW_DEV_BILLING=1 gerekir. Gerçek tahsilat: "iyzico".
PAYMENT_PROVIDER="dev"
# ALLOW_DEV_BILLING="1"

# iyzico (PAYMENT_PROVIDER=iyzico iken zorunlu — lib/billing/providers/iyzico.ts).
# Sandbox hesabı: https://sandbox-merchant.iyzipay.com (ücretsiz). API anahtarları
# panel → Ayarlar → API Anahtarları. merchantId webhook imza doğrulaması için.
# Plan referans kodları: panelde Abonelik → Ürün + Ödeme Planı oluşturunca verilir
# (aylık 99 TL / yıllık 990 TL — lib/billing/plans.ts ile eşleşmeli).
# Prod'a geçerken IYZICO_BASE_URL="https://api.iyzipay.com" yap ve panelden
# webhook URL'ini kaydet: https://ALAN-ADIN/api/webhooks/iyzico
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_MERCHANT_ID=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
IYZICO_PLAN_REF_MONTHLY=""
IYZICO_PLAN_REF_YEARLY=""

# E-posta (şifre sıfırlama — lib/mail/mailer.ts, Resend).
# RESEND_API_KEY boşsa mail gönderilmez; sıfırlama linki sunucu konsoluna basılır
# (lokal dev için yeterli). Gerçek gönderim için resend.com'dan API key al.
RESEND_API_KEY=""
# Gönderen adresi. Doğrulanmış alan adın olunca "Fonly <noreply@alanadi.com>" yap.
MAIL_FROM="Fonly <onboarding@resend.dev>"
# Uygulamanın dış URL'i — sıfırlama linkleri, alarm e-postaları, sitemap ve
# OG etiketleri buradan üretilir. Prod'da https://ALAN-ADIN yap.
APP_URL="http://localhost:3000"

# Sentry hata izleme (opsiyonel). İkisi de boşsa Sentry tamamen devre dışı.
# sentry.io'da ücretsiz hesap → proje oluştur → DSN'i her iki değişkene de yaz.
# (NEXT_PUBLIC_ olan tarayıcı hataları, diğeri sunucu hataları için.)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Zamanlanmış alarm kontrolü (/api/cron/alerts) için paylaşılan sır.
# Prod'da `next start` çalışıyorsa instrumentation.ts zaten 5 dk'da bir kontrol
# eder; bu route dış cron (Vercel Cron, cron-job.org) veya manuel tetik içindir.
# İstek: Authorization: Bearer <secret>  veya  ?secret=<secret>
CRON_SECRET=""
