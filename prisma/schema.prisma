generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  riskProfile   String?       // "low" | "medium" | "high"
  monthlyIncome Int?
  dashboardLayout String?     // JSON: { order: WidgetKey[], hidden: WidgetKey[] } — panel özelleştirmesi
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  watchlist     Watchlist[]
  priceAlerts   PriceAlert[]
  subscription  Subscription?
  portfolioLots PortfolioLot[]
  goals         Goal[]
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions   PushSubscription[]
  otherAssets         OtherAsset[]
}

/// Tarayıcı push aboneliği (Web Push API). Bir kullanıcı birden çok cihaz/
/// tarayıcıdan abone olabilir — her biri ayrı satır. Alarm tetiklendiğinde
/// lib/chart/alerts.ts bu tabloyu okuyup her endpoint'e bildirim gönderir.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Şifre sıfırlama token'ı. Kullanıcı "şifremi unuttum" derse üretilir.
/// GÜVENLİK: ham token DEĞİL, SHA-256 hash'i saklanır (DB sızsa bile linkler
/// kullanılamaz). Ham token yalnızca e-postadaki linkte gider. Tek kullanımlık
/// (kullanılınca/yeni istek gelince silinir) ve `expires` ile süreli (1 saat).
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Birikim/yatırım hedefi. İlerleme, kullanıcının canlı portföy değerine göre
/// hesaplanır (lib/portfolio/aggregate.ts → portfolioSummary.value). targetDate
/// opsiyonel; verilirse kalan süre + aylık ayrılabilir tutara göre tempo gösterilir.
model Goal {
  id         String    @id @default(cuid())
  userId     String
  title      String
  target     Int       // hedef tutar (TL)
  targetDate DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Net değer hesabına giren portföy-dışı kalem — Premium'a özel ("net worth").
/// kind = "asset" (ev, nakit, mevduat...) toplama eklenir, "liability" (kredi,
/// kredi kartı borcu...) çıkarılır. value her zaman güncel TL karşılığıdır —
/// kullanıcı manuel günceller, canlı fiyatlama yok (portföy pozisyonlarının aksine).
model OtherAsset {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  kind      String   @default("asset") // "asset" | "liability"
  value     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Portföy işlemi (alım VEYA satım kaydı). Her satır bir işlemdir.
/// `/portfoy` sayfası slug'a göre gruplayıp ortalama maliyet yöntemiyle
/// pozisyon + gerçekleşen/gerçekleşmemiş K/Z hesaplar (lib/portfolio/aggregate.ts):
/// satışlar o anki ağırlıklı ortalama maliyetten düşülür.
/// slug formatı watchlist/alert ile aynı: "hisse-THYAO", "doviz-USD", "altin-gram", "fon-AAK".
model PortfolioLot {
  id        Int      @id @default(autoincrement())
  userId    String
  slug      String
  side      String   @default("buy") // "buy" | "sell"
  quantity  Float           // adet / birim
  unitCost  Float           // birim fiyat (TL) — alışta maliyet, satışta satış fiyatı
  boughtAt  DateTime @default(now()) // işlem tarihi (satışta satış tarihi)
  note      String?
  /// true ise "deneme portföyü" işlemidir — gerçek para değildir, gerçek
  /// portföy özetine/dashboard'a/e-posta özetlerine ASLA dahil edilmez.
  /// Tüm sorgular bunu açıkça filtrelemeli (bkz. lib/portfolio/aggregate.ts kullanan route'lar).
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDemo])
}

/// Premium abonelik. AI özellikleri ve gelecekteki premium-only feature'lar için.
/// Faz 11.5'te Iyzico/PayTR/Stripe entegrasyonu ile providerSubscriptionId doldurulur.
/// `status = "active" | "trialing"` ve `currentPeriodEnd > now()` ise kullanıcı premium.
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  plan                   String    // "monthly" | "yearly" | "trial"
  status                 String    // "active" | "trialing" | "past_due" | "canceled" | "incomplete"
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean   @default(false)
  trialEnd               DateTime?
  providerSubscriptionId String?
  providerCustomerId     String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])
}

/// Kullanıcının takip listesi. slug formatı "hisse-THYAO", "doviz-USD", vb.
model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    String
  slug      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
  @@index([userId])
}

/// Fiyat alarmı. Eşik aşıldığında triggeredAt set edilir.
model PriceAlert {
  id          Int       @id @default(autoincrement())
  userId      String
  slug        String
  /// "price" (varsayılan, mevcut davranış) | "percent_change" (günlük % değişim)
  triggerType String    @default("price")
  condition   String    // "above" | "below" — percent_change'de yön anlamına gelir
  /// price: mutlak TL seviyesi. percent_change: yüzde puan eşiği (örn. 5 = %5).
  threshold   Float
  active      Boolean   @default(true)
  triggeredAt DateTime?
  acknowledged Boolean  @default(false)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active, triggeredAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// AI tarafından risk/vade kategorisine atanmış BIST hisseleri.
/// Batch script (`scripts/analyze-stocks.ts`) günlük çalışır ve bu tabloyu doldurur.
/// `/kategori/[key]` sayfası bu tabloyu okur:
///   - Free kullanıcılar: yalnızca `isWellKnown = true` (BIST 30) — top 5
///   - Premium kullanıcılar: tüm satırlar, aiScore sırasıyla
/// `modelVersion = "seed"` AI'sız ilk seed; gerçek model ID (örn. "claude-opus-4-7") AI run'larından gelir.
model StockAnalysis {
  symbol         String   @id              // "BIMAS"
  name           String                    // "BİM Mağazalar"
  risk           String                    // "low" | "medium" | "high"
  horizon        String                    // "short" | "long"
  isWellKnown    Boolean  @default(false)  // BIST 30 üyesi mi
  aiScore        Float    @default(50)     // 0-100, premium sıralama
  aiSummary      String?  @db.Text         // tek cümle özet — kart üstü
  aiExplanation  String?  @db.Text         // daha uzun açıklama — kart altı
  analyzedAt     DateTime @default(now())
  modelVersion   String   @default("seed")

  @@index([risk, isWellKnown])
  @@index([horizon, isWellKnown])
  @@index([aiScore])
}
